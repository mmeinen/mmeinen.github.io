      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:www.khronos.org)",
      "WebFetch(domain:wikis.khronos.org)",
      "WebFetch(domain:webglfundamentals.org)",
      "WebFetch(domain:webassembly.github.io)",
