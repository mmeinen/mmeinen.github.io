      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(ls:*)",
      "Bash(rm:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(npm install:*)",
