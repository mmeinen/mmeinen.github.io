  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c \"echo $CLAUDE_FILE_PATHS | grep -q index.html && echo 'Warning: index.html modified -- run tests.html to verify shader invariants' || true\""
          }
        ]
      }
    ]
  },
  "defaultMode": "bypassPermissions"
}
